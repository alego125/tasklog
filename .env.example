# ── PostgreSQL / Neon (Desarrollo y Producción) ────────────────────────
# Obtené tu Connection String en https://neon.tech
DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require

# ── Render / Vercel (Producción) ───────────────────────────────────────
# URL de tu frontend en Vercel (para habilitar CORS en el backend)
FRONTEND_URL=https://tu-app.vercel.app

# ── General ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=flowtracker_dev_secret
